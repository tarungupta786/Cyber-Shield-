# RSA keypair paths for JWT RS256 signing.
# In dev mode, keys are auto-generated at these paths if missing.
# In prod mode, you must generate them yourself (e.g. openssl genrsa).
PRIVATE_KEY_PATH=keys/private.pem
PUBLIC_KEY_PATH=keys/public.pem

# SQLite database path
DB_PATH=cybershield.db

# "dev" or "prod". In prod, all vars below must be set or the app refuses to start.
ENVIRONMENT=dev

# Used for cookie signing. Generate something random:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
COOKIE_SECRET=change-me-to-a-random-string
